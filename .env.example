LLM_PROVIDER=anthropic
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=
LLM_MODEL_NAME=claude-sonnet-4-6
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=64000

# ── EnergyPlus-Agent Plugin ───────────────────────────────────────────────────
# The plugin lives at plugins/energyplus_agent/ (git submodule).
# Run `bash scripts/setup_plugin.sh` once to install its dependencies.
# Then use `python main.py --simulate` to trigger IDF generation + simulation.

# Transport: "stdio" (default) | "http" | "sse" | "streamable_http"
ENERGYPLUS_AGENT_TRANSPORT=stdio

# Override the plugin path (leave blank to use the bundled plugins/energyplus_agent/)
ENERGYPLUS_AGENT_PATH=

# Only needed for http/sse/streamable_http transport:
ENERGYPLUS_AGENT_URL=http://localhost:8000

# EPW weather file path (relative to plugin root, or absolute)
ENERGYPLUS_WEATHER_FILE=data/weather/Shenzhen.epw

# Site location for simulation (defaults: Shenzhen, China)
ENERGYPLUS_LOCATION_NAME=Shenzhen
ENERGYPLUS_LATITUDE=22.55
ENERGYPLUS_LONGITUDE=114.10
ENERGYPLUS_TIMEZONE=8
ENERGYPLUS_ELEVATION=5
